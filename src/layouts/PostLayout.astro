---
import Layout from "./Layout.astro";
import { safeJsonLd } from "@/utils/safeJsonLd";
import config from "@/config";

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  /**
   * Alt text for the dynamic post OG image. The card renders the post
   * title as the headline, so the title itself is the right alt —
   * not the post description, which is body prose.
   */
  ogImageAlt?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  /**
   * Locales this post exists in (translated siblings). Forwarded to
   * `<Layout>` so it emits `og:locale:alternate` only for translations
   * that actually exist, instead of advertising every locale with a
   * 404 sibling URL.
   */
  availableLocales?: readonly string[];
  /**
   * Per-locale sibling URLs. Forwarded so the locale switcher (and
   * future `<link rel="alternate">` head emissions) can route to each
   * sibling's *actual* rendered URL — which may differ from the
   * file-path-derived slug when a frontmatter `slug:` override is in
   * play (e.g. the EN fork of `adding-new-post` ships under
   * `adding-new-posts-in-astropaper-theme`).
   */
  hrefByLocale?: Readonly<Record<string, string>>;
  tags?: readonly string[];
};

const { site } = config;
const {
  title,
  description,
  ogImage,
  ogImageAlt,
  canonicalURL,
  pubDatetime,
  modDatetime,
  availableLocales,
  hrefByLocale,
  tags,
} = Astro.props;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title ?? site.title,
  image: ogImage,
  ...(pubDatetime && { datePublished: pubDatetime.toISOString() }),
  ...(modDatetime && { dateModified: modDatetime.toISOString() }),
  author: [
    {
      "@type": "Person",
      name: site.author,
      ...(site.profile && { url: site.profile }),
    },
  ],
};

const jsonLd = safeJsonLd(structuredData);
---

<Layout
  {title}
  {description}
  {ogImage}
  {ogImageAlt}
  {canonicalURL}
  {availableLocales}
  hrefByLocale={hrefByLocale}
  ogType="article"
>
  <Fragment slot="head">
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }
    {site.author && <meta property="article:author" content={site.author} />}
    {tags?.map(tag => <meta property="article:tag" content={tag} />)}
    {
      site.profile && (
        <meta
          property="twitter:creator"
          content={`@${site.profile.split("/").pop()}`}
        />
      )
    }
    <script type="application/ld+json" is:inline set:html={jsonLd} />
  </Fragment>
  <slot />
</Layout>
