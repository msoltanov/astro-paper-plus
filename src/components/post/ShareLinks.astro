---
import ExternalLink from "@/components/ExternalLink.astro";
import { tplStr, useTranslations } from "@/i18n";
import config from "@/config";
import { getSocialIcons } from "@/utils/socialIcons";
const { shareLinks } = config;
const t = useTranslations(Astro.currentLocale);
// T2-9: reuse the icon map from `@/utils/socialIcons` instead of
// re-running `import.meta.glob("/src/assets/icons/socials/*.svg")`
// here. Both consumers (Socials.astro, this file) used to call the
// glob independently — that's a duplicated static asset manifest
// (bigger Vite analysis), and the absolute-path lookup keys were
// coupled to that exact glob pattern. The shared `getSocialIcons()`
// exposes a name-keyed map; consumers don't have to know the path.
const icons = getSocialIcons();
const pageUrl = Astro.url;
const encodedPageUrl = encodeURIComponent(pageUrl.href);
const platformLabel = (name: string) =>
  name.charAt(0).toUpperCase() + name.slice(1);
const items = shareLinks.map(({ name, url, linkTitle }) => {
  const Icon = icons.get(name);
  const title =
    linkTitle ??
    (name === "mail"
      ? t.post.sharePostViaEmail
      : tplStr(t.post.sharePostOn, { platform: platformLabel(name) }));
  return { url, title, Icon };
});
---

{
  items.some(({ Icon }) => Icon) && (
    <div class="flex flex-none flex-col items-center justify-center gap-1 md:items-start">
      {" "}
      <span class="italic">{t.post.sharePostIntro}</span>{" "}
      <div class="text-center">
        {" "}
        {items.map(({ url, title, Icon }) =>
          Icon ? (
            <ExternalLink
              href={`${url}${encodedPageUrl}`}
              class="group inline-flex scale-90 items-center gap-1 p-2 hover:rotate-6 sm:p-1"
              title={title}
            >
              {" "}
              <Icon
                aria-hidden="true"
                class="inline-block size-6 scale-125 fill-transparent stroke-current stroke-2 opacity-90 group-hover:fill-transparent sm:scale-110"
              />{" "}
              <span class="sr-only">{title}</span>{" "}
            </ExternalLink>
          ) : null
        )}{" "}
      </div>{" "}
    </div>
  )
}
