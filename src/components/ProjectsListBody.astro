---
/**
 * `ProjectsListBody` — shared body for the per-locale projects index.
 *
 * Used by BOTH:
 *   - `src/pages/projects/index.astro`           (default locale, unprefixed URL)
 *   - `src/pages/[locale]/projects/index.astro`  (non-default locales, prefixed URL)
 *
 * The two route files exist only as thin `getStaticPaths` wrappers
 * around this component — they pass the locale + the filtered project
 * slice into it. Mirrors the `GalleriesListBody.astro` /
 * `TagListPageBody.astro` route-dedup pattern (see C3 in issues.md).
 */
import type { CollectionEntry } from "astro:content";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { useTranslations } from "@/i18n";

interface Props {
  locale: string;
  projects: CollectionEntry<"projects">[];
}

const { locale, projects } = Astro.props;
const t = useTranslations(locale);
---

<Breadcrumb />
<Main pageTitle={t.pages.projectsTitle} pageDesc={t.pages.projectsDesc}>
  {
    projects.length === 0 ? (
      <p class="text-muted-foreground italic">{t.pages.projectsEmpty}</p>
    ) : (
      <ProjectCard {locale} {projects} />
    )
  }
</Main>
