---
import config from "@/config";
import { DEFAULT_LOCALE } from "@/i18n/locales";
import { tplStr, useTranslations } from "@/i18n";
import LinkButton from "./LinkButton.astro";
import { getSocialIcons } from "@/utils/socialIcons";
const { site, socials } = config;
const locale = Astro.currentLocale ?? DEFAULT_LOCALE;
const t = useTranslations(locale);
const iconModules = getSocialIcons();
// M15 (issues.md): a renamed or deleted social SVG used to make the
// footer icon silently disappear — `iconModules.get(...)` returned
// `undefined` and the LinkButton rendered without an `<Icon>`. Pin the
// contract: every entry in `socials` must resolve to a module. We log
// in dev (cheap early warning) and throw at build time in CI so the
// regression can't ship.
//
// T2-9: the lookup is now name-keyed (`iconsByName.get("github")`)
// instead of absolute-path-keyed. The path-to-name mapping lives in
// `src/utils/socialIcons.ts` so a future move of the icons folder
// (or a glob-pattern change) doesn't break every consumer.
for (const { name } of socials) {
  if (!iconModules.has(name)) {
    const msg =
      `[Socials] config.socials declares name=${JSON.stringify(name)} but ` +
      `no social-icon SVG was found for that name. Either add the missing ` +
      `asset under src/assets/icons/socials/, or remove the entry from ` +
      `socials in astro-paper.config.ts.`;
    if (import.meta.env.DEV) {
      // eslint-disable-next-line no-console
      console.warn(msg);
    } else {
      throw new Error(msg);
    }
  }
}
const items = socials.map(({ name, url, linkTitle }) => {
  const Icon = iconModules.get(name);
  const title =
    linkTitle ??
    (url.startsWith("mailto:") || name === "mail"
      ? tplStr(t.a11y.sendEmail, { title: site.title })
      : tplStr(t.a11y.socialOn, {
          title: site.title,
          platform: name.charAt(0).toUpperCase() + name.slice(1),
        }));
  return { url, title, Icon };
});
---

<div class="flex flex-wrap items-center gap-1">
  {
    items.map(({ url, title, Icon }) =>
      Icon ? (
        <LinkButton href={url} class="p-2 hover:rotate-6 sm:p-1" title={title}>
          {" "}
          <Icon
            aria-hidden="true"
            class="inline-block size-6 scale-125 fill-transparent stroke-current stroke-2 opacity-90 group-hover:fill-transparent sm:scale-110"
          />{" "}
          <span class="sr-only">{title}</span>{" "}
        </LinkButton>
      ) : null
    )
  }
</div>
