---
import type { CollectionEntry } from "astro:content";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { getProjectUrl } from "@/utils/getProjectPaths";
import { parseDateInTz } from "@/utils/parseDateInTz";
import { projectStatusLabel } from "@/utils/projectStatusLabel";
import { tplStr, useTranslations, formatDate } from "@/i18n";
import config from "@/config";

type Props = {
  /** Locale code — used to localize links. */
  locale: string;
  /** Project entries to render. */
  projects: CollectionEntry<"projects">[];
};

const { locale, projects } = Astro.props;
const t = useTranslations(locale);

function projectUrl(project: CollectionEntry<"projects">): string {
  return getProjectUrl(
    project.id,
    project.filePath as string | undefined,
    locale,
    project.data.slug
  );
}

// Resolve a project's `pubDatetime` to an absolute Date (honoring its
// declared timezone) and format it via the centralized helper. The
// compact `{ year: "numeric", month: "short" }` shape lives in
// `config.site.dateFormat.project` so the user can override it globally.
function formatProjectDate(d: string | Date, timezone?: string): string {
  const date = parseDateInTz(d, timezone);
  return formatDate(date, locale, config.site.dateFormat.project);
}

function statusColor(status: CollectionEntry<"projects">["data"]["status"]) {
  switch (status) {
    case "shipped":
      return "bg-emerald-500/10 text-emerald-700 dark:text-emerald-400";
    case "in-progress":
      return "bg-amber-500/10 text-amber-700 dark:text-amber-400";
    case "archived":
      return "bg-zinc-500/10 text-zinc-600 dark:text-zinc-400";
  }
}
---

<ul
  data-projects-list
  class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"
>
  {
    projects.map(project => (
      <li class="border-border bg-card text-card-foreground hover:border-accent/40 hover:bg-card/80 group flex flex-col gap-3 rounded-lg border p-5 transition">
        {" "}
        <div class="flex flex-wrap items-center justify-between gap-2 text-xs">
          {" "}
          <span class="text-muted-foreground font-mono">
            {" "}
            {formatProjectDate(
              project.data.pubDatetime,
              project.data.timezone
            )}{" "}
          </span>{" "}
          <span
            class:list={[
              "rounded-full px-2 py-0.5 text-[10px] font-medium tracking-wider uppercase",
              statusColor(project.data.status),
            ]}
          >
            {" "}
            {projectStatusLabel(project.data.status, t.project)}{" "}
          </span>{" "}
        </div>{" "}
        <h3 class="text-lg leading-tight font-semibold">
          {" "}
          <a
            href={projectUrl(project)}
            class="decoration-none hover:underline focus-visible:underline"
          >
            {" "}
            {project.data.title}{" "}
          </a>{" "}
        </h3>{" "}
        <p class="text-muted-foreground text-sm">
          {" "}
          {project.data.summary ?? project.data.description}{" "}
        </p>
        {project.data.tech.length > 0 && (
          <ul class="mt-auto flex flex-wrap gap-1.5 pt-2">
            {" "}
            {project.data.tech.map(t => (
              <li class="bg-muted text-muted-foreground rounded px-2 py-0.5 text-[10px] tracking-wider uppercase">
                {" "}
                {t}{" "}
              </li>
            ))}{" "}
          </ul>
        )}{" "}
        <div class="mt-1 flex items-center gap-3 text-sm">
          {" "}
          <a
            href={projectUrl(project)}
            class="text-accent inline-flex items-center gap-1 hover:underline"
            aria-label={tplStr(t.a11y.readMoreAbout, {
              title: project.data.title,
            })}
          >
            {" "}
            {t.project.viewProject}{" "}
            <IconArrowRight
              aria-hidden="true"
              class="size-4 rtl:-rotate-180"
            />{" "}
          </a>{" "}
        </div>{" "}
      </li>
    ))
  }
</ul>
