---
import { type CollectionEntry, getCollection, render } from "astro:content";
// Side-effect import: Astro bundles PhotoSwipe CSS into the page's
// stylesheet, so it ships with the rest of the gallery assets and
// doesn't depend on a third-party CDN at runtime.
import "photoswipe/dist/photoswipe.css";
import Layout from "@/layouts/Layout.astro";
import GalleryDetailBody from "@/components/GalleryDetailBody.astro";
import { getGallerySlugSegments } from "@/utils/getGalleryPaths";
import { groupNonDefaultLocale } from "@/utils/groupNonDefaultLocale";
import { galleryFilter } from "@/utils/galleryFilter";
import { coverImageSrc } from "@/utils/coverImageSrc";
import {
  buildContentTranslationGroups,
  findContentSiblings,
} from "@/utils/contentSiblings";
import { localeParam } from "@/i18n/locales";
import config from "@/config";

export async function getStaticPaths() {
  if (!config.features.enableGalleries) return [];

  // Load + filter once. The per-locale partition below and the
  // sibling-map below are both built from this same `renderable`
  // set, so an entry only appears in `availableLocales` /
  // `hrefByLocale` if it actually renders in its declared locale.
  // Building the group from the unfiltered collection (the previous
  // shape) would advertise a default-locale URL that the draft
  // filter just dropped — translated pages would 404 their own
  // locale switcher / hreflang links.
  const all = await getCollection("galleries");
  const renderable = all.filter(galleryFilter);
  const byLocale = await groupNonDefaultLocale<CollectionEntry<"galleries">>(
    () => Promise.resolve(renderable)
  );
  // Translation groups span every locale; sibling lookup is O(1)
  // per entry once the map is built.
  const translationGroups = buildContentTranslationGroups(
    "galleries",
    renderable
  );
  const allPaths: Array<{
    params: { locale: string; slug: string };
    props: {
      gallery: CollectionEntry<"galleries">;
      siblings: ReturnType<typeof findContentSiblings<"galleries">>;
    };
  }> = [];

  for (const [locale, galleries] of byLocale) {
    for (const gallery of galleries) {
      const siblings = findContentSiblings(
        "galleries",
        gallery,
        translationGroups
      );
      allPaths.push({
        params: {
          locale,
          slug: getGallerySlugSegments(
            gallery.id,
            gallery.filePath as string | undefined,
            gallery.data.slug
          ),
        },
        props: { gallery, siblings },
      });
    }
  }

  return allPaths;
}

const { gallery, siblings } = Astro.props;
const locale = localeParam(Astro.params.locale);

const { title, description, images, coverImage } = gallery.data;

const { Content } = await render(gallery);

const rawCover = coverImageSrc(coverImage) ?? images[0]?.src?.src;
const ogImage = rawCover ? new URL(rawCover, Astro.url.origin).href : undefined;
---

<Layout
  title={`${title} | ${config.site.title}`}
  description={description}
  ogImage={ogImage}
  availableLocales={siblings.availableLocales}
  hrefByLocale={siblings.hrefByLocale}
>
  <GalleryDetailBody {locale} {gallery}>
    <Content />
  </GalleryDetailBody>
</Layout>

<!-- PhotoSwipe v5 — gallery lightbox.
  - CSS is imported via the page frontmatter and bundled with the page stylesheet (no CDN).
  - JS is dynamically imported via the script below and lazy-loaded by PhotoSwipe itself on first open.
-->
<script>
  import {
    initGalleryLightbox,
    destroyGalleryLightbox,
  } from "@/scripts/galleryLightbox";
  initGalleryLightbox();

  document.addEventListener("astro:after-swap", () => {
    initGalleryLightbox();
  });
  document.addEventListener("astro:before-swap", destroyGalleryLightbox);
</script>
